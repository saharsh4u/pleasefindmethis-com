{
  "functions": {
    "api/**/*.mjs": {
      "maxDuration": 30,
      "excludeFiles": "{.vercel,dist,public}/**"
    }
  },
  "redirects": [
    {
      "source": "/:path((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": {
            "eq": "www.pleasefindmethis.com"
          }
        }
      ],
      "destination": "https://pleasefindmethis.com/:path*",
      "permanent": true
    },
    {
      "source": "/guides",
      "destination": "/guides/",
      "permanent": true
    },
    {
      "source": "/guides/:slug",
      "destination": "/guides/:slug/",
      "permanent": true
    },
    {
      "source": "/requests",
      "destination": "/requests/",
      "permanent": true
    },
    {
      "source": "/requests/:slug",
      "destination": "/requests/:slug/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": {
            "eq": "pleasefindmethis-com.vercel.app"
          }
        }
      ],
      "destination": "https://pleasefindmethis.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/auth",
      "destination": "/index.html"
    },
    {
      "source": "/post/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/browse",
      "destination": "/index.html"
    },
    {
      "source": "/browse/all",
      "destination": "/index.html"
    },
    {
      "source": "/bounty/detail",
      "destination": "/index.html"
    },
    {
      "source": "/requests/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/submit-find",
      "destination": "/index.html"
    },
    {
      "source": "/poster-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/finder-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/messages",
      "destination": "/index.html"
    },
    {
      "source": "/dispute",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/refunds",
      "destination": "/index.html"
    },
    {
      "source": "/account/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    }
  ]
}
