VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_PUBLIC_APP_URL=https://pleasefindmethis.com
PUBLIC_APP_URL=https://pleasefindmethis.com

# Google Search Console + analytics.
# Search Console tracks search/indexing, not product events. Use the verification
# token from Search Console's HTML tag method here; submit /sitemap.xml in GSC.
VITE_GOOGLE_SITE_VERIFICATION=your-google-search-console-html-tag-token

# Browser tracking. Prefer GTM when marketing tags will expand beyond GA4.
VITE_GTM_ID=GTM-XXXXXXX
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_DIRECT_GTAG_EVENTS=false
VITE_ANALYTICS_DEBUG_MODE=false

# Server-only. Never expose this with a VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Server-side GA4 Measurement Protocol for confirmed checkout webhook events.
# Create this secret in GA4 Admin > Data streams > Measurement Protocol API secrets.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-measurement-protocol-api-secret
GA4_MEASUREMENT_PROTOCOL_DEBUG=false

# Active hosted checkout provider. Use "whop" only after Whop approves checkout for this marketplace/finder-payout flow.
PAYMENT_PROVIDER=lemonsqueezy

# Lemon Squeezy setup for this app:
# 1. Create an API key in Settings > API.
# 2. Create a one-time product/variant for funding request rewards.
# 3. Point a Lemon Squeezy webhook at /api/lemonsqueezy/webhook for order_created and order_refunded.
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-lemonsqueezy-store-id
LEMONSQUEEZY_VARIANT_ID=your-lemonsqueezy-one-time-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret
LEMONSQUEEZY_TEST_MODE=false

# Dodo setup for this app:
# Dodo's Merchant Acceptance Policy may reject marketplace, physical-goods, escrow, stored-value, or forwarded-payout models.
# Keep Dodo checkout disabled unless Dodo explicitly approves this exact new website and business model in a new business/product review.
# 1. Create a secret API key in your Dodo dashboard.
# 2. Create a one-time pay-what-you-want product because each request has a different funded reward total.
# 3. Point a Dodo webhook at /api/dodo/webhook and copy the signing secret here so paid/refunded/disputed states update the marketplace ledger.
DODO_PAYMENTS_API_KEY=your-dodo-secret-api-key
DODO_PRODUCT_ID=your-one-time-pay-what-you-want-product-id
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
DODO_PAYMENTS_ENVIRONMENT=test
DODO_MARKETPLACE_CHECKOUT_ENABLED=false

# Whop setup for this app:
# 1. Create/verify your Whop account as an individual or sole proprietor.
# 2. Create a server-side API key with checkout configuration, plan, and webhook permissions.
# 3. Set PAYMENT_PROVIDER=whop after sandbox checkout and webhook confirmation pass.
# 4. Point a Whop webhook at /api/whop/webhook for payment.succeeded, payment.failed, refund.*, and dispute.* events.
# 5. Connected-account finder payouts require Whop for Platforms access; contact Whop before automating transfers.
WHOP_API_KEY=your-whop-api-key
WHOP_COMPANY_ID=your-whop-company-id
WHOP_PLATFORM_COMPANY_ID=
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret
WHOP_ENVIRONMENT=sandbox
WHOP_API_VERSION_DATE=2026-07-01
# Temporary sandbox testing on a production deployment. Keep false for real money.
WHOP_ALLOW_SANDBOX_ON_PRODUCTION=false
