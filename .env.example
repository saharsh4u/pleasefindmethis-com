VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
PUBLIC_APP_URL=https://pleasefindmethis.com

# Server-only. Never expose this with a VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Active hosted checkout provider. Use "lemonsqueezy" while Dodo live review is pending, or "dodo" after Dodo is enabled.
PAYMENT_PROVIDER=lemonsqueezy

# Lemon Squeezy setup for this app:
# 1. Create an API key in Settings > API.
# 2. Create a one-time product/variant for funding request rewards.
# 3. Point a Lemon Squeezy webhook at /api/lemonsqueezy/webhook for order_created and order_refunded.
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-lemonsqueezy-store-id
LEMONSQUEEZY_VARIANT_ID=your-lemonsqueezy-one-time-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret
LEMONSQUEEZY_TEST_MODE=false

# Dodo setup for this app:
# 1. Create a secret API key in your Dodo dashboard.
# 2. Create a one-time pay-what-you-want product because each request has a different funded reward total.
# 3. Point a Dodo webhook at /api/dodo/webhook and copy the signing secret here so paid/refunded/disputed states update the marketplace ledger.
DODO_PAYMENTS_API_KEY=your-dodo-secret-api-key
DODO_PRODUCT_ID=your-one-time-pay-what-you-want-product-id
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
DODO_PAYMENTS_ENVIRONMENT=test
