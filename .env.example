VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_PUBLIC_APP_URL=https://pleasefindmethis.com
PUBLIC_APP_URL=https://pleasefindmethis.com

# Google Search Console + analytics.
# Search Console tracks search/indexing, not product events. Use the verification
# token from Search Console's HTML tag method here; submit /sitemap.xml in GSC.
VITE_GOOGLE_SITE_VERIFICATION=your-google-search-console-html-tag-token

# Browser tracking. Prefer GTM when marketing tags will expand beyond GA4.
VITE_GTM_ID=GTM-XXXXXXX
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_DIRECT_GTAG_EVENTS=false
VITE_ANALYTICS_DEBUG_MODE=false
DATAFAST_WEBSITE_ID=your-datafast-website-id
VITE_DATAFAST_WEBSITE_ID=your-datafast-website-id

# Server-only. Never expose this with a VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Requests and public clues are free. This app has no commercial transaction configuration.
